          </a>
          <a href="https://tiktok.com/@munleruk" aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
          </a>
        </div>
        <form class="footer-newsletter" id="footer-newsletter-form">
          <p class="footer-newsletter-label">Stay in the loop</p>
          <div class="footer-newsletter-field">
            <input type="email" name="email" placeholder="Your email address" required
                   class="footer-newsletter-input" id="footer-newsletter-email"
                   autocomplete="email" aria-label="Email address for newsletter">
            <button type="submit" class="footer-newsletter-btn" aria-label="Subscribe">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <p class="footer-newsletter-success" id="footer-newsletter-success" style="display:none">Thank you. You're on the list.</p>
          <p class="footer-newsletter-error" id="footer-newsletter-error" style="display:none">Something went wrong. Please try again.</p>
        </form>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h5>Shop</h5>
          <ul>
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections/mirrors">Mirrors</a></li>
            <li><a href="/collections/furniture">Furniture</a></li>
            <li><a href="/collections/all">New Arrivals</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Company</h5>
          <ul>
            <li><a href="/pages/about-munler">About Us</a></li>
            <li><a href="/pages/about-munler">Our Story</a></li>
            <li><a href="/pages/trade">Trade</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Support</h5>
          <ul>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/warranty">Warranty</a></li>
            <li><a href="/pages/shipping-returns">Shipping &amp; Returns</a></li>
            <li><a href="/pages/care-guide">Care Guide</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Terms &amp; Policies</h5>
          <ul>
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
            <li><a href="/policies/refund-policy">Return &amp; Refund Policy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="payment-row">
      <div class="payment-icons">
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Visa"><rect width="46" height="30" rx="4" fill="#1A1F71"/><text x="23" y="20" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="900" font-style="italic" fill="#FFFFFF" letter-spacing="1">VISA</text></svg>
