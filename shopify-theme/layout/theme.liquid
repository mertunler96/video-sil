        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Apple Pay"><rect width="46" height="30" rx="4" fill="#000000"/><text x="23" y="20" text-anchor="middle" font-family="-apple-system,Arial,sans-serif" font-size="11" font-weight="500" fill="#FFFFFF">Pay</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Google Pay"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><text x="7" y="20" font-family="Arial,sans-serif" font-size="13" font-weight="700" fill="#4285F4">G</text><text x="19" y="20" font-family="Arial,sans-serif" font-size="11" font-weight="400" fill="#5F6368">Pay</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="PayPal"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><text x="5" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="900" fill="#003087">Pay</text><text x="26" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="900" fill="#009CDE">Pal</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Klarna"><rect width="46" height="30" rx="4" fill="#FFB3C7"/><text x="23" y="20" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="10" font-weight="700" fill="#000000" letter-spacing="0.3">klarna</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Maestro"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><circle cx="18" cy="15" r="8" fill="#0099DF" opacity="0.9"/><circle cx="28" cy="15" r="8" fill="#EB001B" opacity="0.85"/><path d="M23 7.7a8 8 0 0 1 0 14.6A8 8 0 0 1 23 7.7z" fill="#6C6BBD" opacity="0.9"/></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Discover"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><circle cx="34" cy="15" r="10" fill="#FF6600"/><text x="4" y="19" font-family="Arial,Helvetica,sans-serif" font-size="7" font-weight="700" fill="#231F20">DISC</text><text x="4" y="26" font-family="Arial,Helvetica,sans-serif" font-size="7" font-weight="700" fill="#231F20">OVER</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Diners Club"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><circle cx="19" cy="15" r="8" fill="none" stroke="#004A97" stroke-width="1.8"/><circle cx="27" cy="15" r="8" fill="none" stroke="#004A97" stroke-width="1.8"/><text x="23" y="28" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="5" font-weight="600" fill="#004A97">DINERS</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Shop Pay"><rect width="46" height="30" rx="4" fill="#5A31F4"/><text x="23" y="19" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="8" font-weight="700" fill="#FFFFFF" letter-spacing="0.2">SHOP</text><text x="23" y="27" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="8" font-weight="700" fill="#FFFFFF" letter-spacing="0.2">PAY</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="UnionPay"><rect width="46" height="30" rx="4" fill="#C0131E"/><rect x="27" y="0" width="19" height="30" rx="0" fill="#167DB7"/><rect x="25" y="0" width="4" height="30" fill="#FFFFFF"/><text x="14" y="20" text-anchor="middle" font-family="Arial,sans-serif" font-size="9" font-weight="700" fill="#FFFFFF">UP</text></svg>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} MUNLER. All rights reserved.</p>
      <p>Crafted with intention.</p>
    </div>
  </footer>

  <script>
  window.MUNLER_SEARCH_PRODUCTS = [{% for p in collections['all'].products limit: 8 %}{name:{{ p.title | json }},img:{{ p.featured_image | img_url: '300x' | prepend: 'https:' | json }},url:{{ p.url | json }},price:{{ p.price | money | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}];
  </script>
  <script src="{{ 'main.js' | asset_url }}" defer></script>
  <script>
  (function() {
    var form = document.getElementById('footer-newsletter-form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = document.getElementById('footer-newsletter-email').value.trim();
      if (!email) return;
      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=U2UQE5', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'revision': '2023-12-15' },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: {
              profile: { data: { type: 'profile', attributes: { email: email } } }
            },
            relationships: {
              list: { data: { type: 'list', id: 'WqGLDz' } }
            }
          }
        })
      })
      .then(function(res) {
        if (res.ok || res.status === 202) {
          document.getElementById('footer-newsletter-success').style.display = 'block';
          document.getElementById('footer-newsletter-error').style.display = 'none';
          form.querySelector('input[type="email"]').value = '';
          var _learnq = window._learnq || [];
          _learnq.push(['identify', { '$email': email }]);
        } else {
          document.getElementById('footer-newsletter-error').style.display = 'block';
        }
      })
      .catch(function() {
        document.getElementById('footer-newsletter-error').style.display = 'block';
      });
    });
  })();
  </script>
</body>
</html>
