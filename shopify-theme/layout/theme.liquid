<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: shop.description | default: 'MUNLER — Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' }}">
  {% if settings.google_site_verification != blank %}<meta name="google-site-verification" content="{{ settings.google_site_verification }}">{% endif %}
  {% if settings.bing_site_verification != blank %}<meta name="msvalidate.01" content="{{ settings.bing_site_verification }}">{% endif %}
  {% if settings.pinterest_site_verification != blank %}<meta name="p:domain_verify" content="{{ settings.pinterest_site_verification }}">{% endif %}
  <title>{% if template == 'index' %}MUNLER — Premium Home Objects{% elsif page_title %}{{ page_title }} | MUNLER{% else %}MUNLER{% endif %}</title>
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="MUNLER">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:locale" content="en_GB">
  {% if template == 'index' %}
    <meta property="og:type" content="website">
    <meta property="og:title" content="MUNLER — Premium Home Objects">
    <meta property="og:description" content="{{ shop.description | default: 'Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' | escape }}">
    {% if settings.share_image %}<meta property="og:image" content="https:{{ settings.share_image | img_url: '1200x630' }}">{% endif %}
  {% elsif template contains 'product' %}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title | escape }} | MUNLER">
    <meta property="og:description" content="{{ product.description | strip_html | truncate: 160 | escape }}">
    <meta property="og:image" content="https:{{ product.featured_image | img_url: '1200x630' }}">
    <meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
    <meta property="product:price:currency" content="GBP">
  {% elsif template contains 'collection' %}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ collection.title | escape }} | MUNLER">
    <meta property="og:description" content="{{ collection.description | strip_html | truncate: 160 | default: 'Shop the MUNLER collection.' | escape }}">
    {% if collection.image %}<meta property="og:image" content="https:{{ collection.image | img_url: '1200x630' }}">{% elsif settings.share_image %}<meta property="og:image" content="https:{{ settings.share_image | img_url: '1200x630' }}">{% endif %}
  {% else %}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{% if page_title %}{{ page_title | escape }} | MUNLER{% else %}MUNLER{% endif %}">
    <meta property="og:description" content="{{ page_description | default: shop.description | default: 'Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' | escape }}">
    {% if settings.share_image %}<meta property="og:image" content="https:{{ settings.share_image | img_url: '1200x630' }}">{% endif %}
  {% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@munleruk">
  <meta name="twitter:title" content="{% if template == 'index' %}MUNLER — Premium Home Objects{% elsif page_title %}{{ page_title | escape }} | MUNLER{% else %}MUNLER{% endif %}">
  <meta name="twitter:description" content="{{ page_description | default: shop.description | default: 'Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' | escape }}">
  {% if template contains 'product' and product.featured_image %}
    <meta name="twitter:image" content="https:{{ product.featured_image | img_url: '1200x628' }}">
  {% elsif settings.share_image %}
    <meta name="twitter:image" content="https:{{ settings.share_image | img_url: '1200x628' }}">
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <link rel="stylesheet" href="{{ 'style.css' | asset_url }}">
  {% if template contains 'product' %}
    <link rel="stylesheet" href="{{ 'product.css' | asset_url }}">
  {% endif %}
  {% unless template == 'index' or template contains 'product' or template == 'cart' %}
    <link rel="stylesheet" href="{{ 'pages.css' | asset_url }}">
  {% endunless %}
  {% if template == 'policy' %}<style>main h1{position:absolute!important;width:1px!important;height:1px!important;padding:0!important;margin:-1px!important;overflow:hidden!important;clip:rect(0,0,0,0)!important;white-space:nowrap!important;border:0!important}</style>{% endif %}

  {% if template == 'index' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "MUNLER",
    "url": "{{ shop.url }}",
    {% if settings.share_image %}"logo": "https:{{ settings.share_image | img_url: '600x' }}",{% endif %}
    "description": {{ shop.description | default: 'Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' | json }},
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@munler.co.uk",
      "contactType": "customer service",
      "areaServed": "GB",
      "availableLanguage": "English"
    },
    "sameAs": [
      "https://instagram.com/munleruk",
      "https://pinterest.com/munleruk",
      "https://tiktok.com/@munleruk"
    ]
  }
  </script>
  {% endif %}
</head>
<body>

  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <div class="announcement-track">
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
    </div>
  </div>

  <!-- Header -->
  <header class="site-header" id="site-header">
    <div class="header-inner">
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav-left">
        <a href="/collections/all" class="nav-link">Shop</a>
        <a href="/collections" class="nav-link">Collections</a>
        <a href="/pages/trade" class="nav-link">Trade</a>
      </nav>

      <a href="/" class="site-logo">MUNLER</a>

      <div class="nav-right">
        <a href="/pages/about-munler" class="nav-link">About</a>
        <a href="/pages/contact" class="nav-link">Contact</a>
        <div class="nav-icons">
          <button class="icon-btn" aria-label="Search">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
          <a href="/cart" class="icon-btn cart-btn" aria-label="Cart">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-count" id="cart-count">{{ cart.item_count }}</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/collections/all">Shop</a>
        <a href="/collections">Collections</a>
        <a href="/pages/trade">Trade</a>
        <a href="/pages/about-munler">About</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>
  </header>

  <main>
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
