{% render 'page-hero', img: 'https://munler.co.uk/cdn/shop/files/ayna_cercevelerini_siyah_yap_2K_202605251344.jpg', title: 'Contact' %}

<section class="contact-section">
  <div class="container">
    <div class="contact-grid">

      <!-- Form (left) -->
      <div>
        <div class="section-header" style="text-align:left; margin-bottom:3rem;">
          <span class="section-label">Send a Message</span>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.2rem); margin-bottom:0;">How can we help?</h2>
        </div>

        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div style="padding:1.5rem; background:#f0f7f0; border:1px solid #c3e0c3; margin-bottom:1.5rem;">
              <p style="color:#2d6a2d; font-size:0.9rem;">Thank you for your message. We'll be in touch within one working day.</p>
            </div>
          {% endif %}
          {% if form.errors %}
            <div style="padding:1rem; background:#fff0f0; border:1px solid #e0c3c3; margin-bottom:1.5rem;">
              <p style="color:#6a2d2d; font-size:0.85rem;">{{ form.errors | default_errors }}</p>
            </div>
          {% endif %}

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.4rem; margin-bottom:1.4rem;">
            <div class="form-field">
              <label for="ContactFormName">Name</label>
              <input type="text" id="ContactFormName" name="contact[name]" placeholder="Your name" value="{{ form.name }}" required>
            </div>
            <div class="form-field">
              <label for="ContactFormEmail">Email</label>
              <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="your@email.com" value="{{ form.email }}" required>
            </div>
          </div>
          <div class="form-field">
            <label for="ContactFormSubject">Subject</label>
            <select id="ContactFormSubject" name="contact[subject]">
              <option value="">Select a topic</option>
              <option value="Order enquiry">Order enquiry</option>
              <option value="Product question">Product question</option>
              <option value="Returns & refunds">Returns &amp; refunds</option>
              <option value="Delivery">Delivery</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ContactFormMessage">Message</label>
            <textarea id="ContactFormMessage" name="contact[body]" placeholder="Tell us how we can help you..." rows="6" required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="btn-submit">Send Message</button>
        {% endform %}
      </div>

      <!-- Info (right) -->
      <div class="contact-info">

        <div class="contact-info-block">
          <h4>Response Time</h4>
          <p>We aim to respond to all enquiries within 24 hours, Monday to Friday. Weekend messages are answered first thing on Monday.</p>
        </div>

        <div class="contact-info-block">
          <h4>Email</h4>
          <a href="mailto:info@munler.co.uk">info@munler.co.uk</a>
        </div>

        <div class="contact-info-block">
          <h4>Follow Us</h4>
          <div class="contact-social">
            <a href="https://instagram.com/munleruk" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://pinterest.com/munleruk" aria-label="Pinterest">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.77 1.27-5.38 1.27-5.38s-.32-.65-.32-1.6c0-1.5.87-2.63 1.95-2.63.92 0 1.37.69 1.37 1.52 0 .93-.59 2.31-.9 3.59-.25 1.07.54 1.94 1.59 1.94 1.91 0 3.19-2.47 3.19-5.38 0-2.22-1.49-3.88-3.97-3.88-2.9 0-4.71 2.17-4.71 4.59 0 .84.24 1.42.62 1.88.17.21.19.29.13.52-.04.17-.14.57-.18.73-.06.23-.24.32-.44.23-1.24-.51-1.82-1.88-1.82-3.42 0-2.55 2.16-5.65 6.44-5.65 3.47 0 5.75 2.53 5.75 5.24 0 3.6-1.99 6.32-4.9 6.32-.98 0-1.9-.53-2.22-1.12l-.63 2.47c-.22.87-.83 1.95-1.25 2.61.94.29 1.94.45 2.97.45 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </a>
          </div>
        </div>

        <div class="contact-info-block">
          <h4>Frequently Asked</h4>
          <div class="faq-list">
            <div class="faq-item">
              <p class="faq-q">How long does delivery take?</p>
              <p class="faq-a">Orders are dispatched within 3–5 business days. Delivery typically takes 5–8 business days from order date.</p>
            </div>
            <div class="faq-item">
              <p class="faq-q">Can I return my order?</p>
              <p class="faq-a">Yes. We accept returns within 30 days of receipt. Refunds are processed within 5–7 business days.</p>
            </div>
            <div class="faq-item">
              <p class="faq-q">Is delivery really free?</p>
              <p class="faq-a">Free tracked and insured delivery on all UK orders.</p>
            </div>
            <div class="faq-item">
              <p class="faq-q">What is the warranty?</p>
              <p class="faq-a">All MUNLER products come with a 5-year warranty against frame corrosion and structural defects.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
