{% render 'page-hero', img: 'https://munler.co.uk/cdn/shop/files/ayna_cercevelerini_siyah_yap_2K_202605251344.jpg', title: 'Contact' %}

<section class="contact-body">
  <div class="contact-inner container">
    <div class="contact-info reveal">
      <span class="section-label">Get in Touch</span>
      <h2>We'd Love to Hear From You</h2>
      <p>Whether you have a question about a product, need help with an order, or are interested in our Trade Programme — we're here to help.</p>
      <div class="contact-details">
        <div class="contact-detail-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div><p class="contact-detail-label">Email</p><a href="mailto:info@munler.co.uk">info@munler.co.uk</a></div>
        </div>
        <div class="contact-detail-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div><p class="contact-detail-label">Response Time</p><p>Within 1 working day</p></div>
        </div>
      </div>
    </div>

    <div class="contact-form-wrap reveal">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="form-success" style="padding: 2rem; background: #f0f7f0; border: 1px solid #c3e0c3; margin-bottom: 2rem;">
            <p style="color: #2d6a2d; font-size: 0.9rem;">Thank you for your message. We'll be in touch within one working day.</p>
          </div>
        {% endif %}
        {% if form.errors %}
          <div class="form-error" style="padding: 1rem; background: #fff0f0; border: 1px solid #e0c3c3; margin-bottom: 1.5rem;">
            <p style="color: #6a2d2d; font-size: 0.85rem;">{{ form.errors | default_errors }}</p>
          </div>
        {% endif %}
        <div class="form-group">
          <label for="ContactFormName">Name</label>
          <input type="text" id="ContactFormName" name="contact[name]" placeholder="Your full name" value="{{ form.name }}" required>
        </div>
        <div class="form-group">
          <label for="ContactFormEmail">Email</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="your@email.com" value="{{ form.email }}" required>
        </div>
        <div class="form-group">
          <label for="ContactFormSubject">Subject</label>
          <input type="text" id="ContactFormSubject" name="contact[subject]" placeholder="How can we help?">
        </div>
        <div class="form-group">
          <label for="ContactFormMessage">Message</label>
          <textarea id="ContactFormMessage" name="contact[body]" placeholder="Your message..." rows="6" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="btn btn-dark" style="width: 100%;">Send Message</button>
      {% endform %}
    </div>
  </div>
</section>
