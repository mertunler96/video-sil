<style>
.warranty-hero{position:relative;height:90vh;min-height:560px;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
.warranty-hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
.warranty-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,10,10,.55),rgba(10,10,10,.45))}
.warranty-hero-content{position:relative;z-index:2;padding:0 var(--gutter);max-width:680px}
.warranty-hero-title{font-family:var(--font-serif);font-size:clamp(3.5rem,7vw,6.5rem);font-weight:400;color:#fff;line-height:1.05}
.warranty-body{padding:8rem 0;background:#fff}
.policy-updated{font-family:var(--font-sans);font-size:.72rem;font-weight:300;color:var(--color-mid);letter-spacing:.08em;margin-bottom:3.5rem;padding-bottom:2rem;border-bottom:1px solid var(--color-border)}
.policy-section{margin-bottom:3.5rem;padding-bottom:3.5rem;border-bottom:1px solid var(--color-border)}
.policy-section h2{font-family:var(--font-serif)!important;font-size:clamp(1.3rem,2.5vw,1.9rem)!important;font-weight:400!important;color:var(--color-dark)!important;margin-bottom:1.2rem!important;line-height:1.2!important}
.policy-section h3{font-family:var(--font-sans)!important;font-size:.78rem!important;font-weight:500!important;letter-spacing:.1em!important;text-transform:uppercase!important;color:var(--color-dark)!important;margin-bottom:.8rem!important;margin-top:1.8rem!important;font-style:normal!important}
.policy-section p{font-size:.88rem;line-height:1.9;color:var(--color-mid);margin-bottom:1rem}
.policy-section ul,.policy-section ol{padding-left:1.4rem;margin-bottom:1rem}
.policy-section li{font-size:.88rem;line-height:1.85;color:var(--color-mid);margin-bottom:.4rem}
.policy-section a{color:var(--color-dark)!important;text-decoration:underline;text-underline-offset:3px}
.policy-section strong{color:var(--color-dark);font-weight:500}
</style>
{% case policy.url %}
  {% when '/policies/privacy-policy' %}
    {% assign hero_img = 'https://munler.co.uk/cdn/shop/files/aynaya_odakli_shotlar_ver_2K_202605251702.jpg' %}
  {% when '/policies/refund-policy' %}
    {% assign hero_img = 'https://munler.co.uk/cdn/shop/files/ayna_cercevelerini_siyah_yap_2K_202605251344.jpg' %}
  {% when '/policies/shipping-policy' %}
    {% assign hero_img = 'https://munler.co.uk/cdn/shop/files/ayna_cercevesini_champagne_gold_yap_202605251429.jpg' %}
  {% when '/policies/terms-of-service' %}
    {% assign hero_img = 'https://munler.co.uk/cdn/shop/files/Make_the_armchair_202511231422.jpg' %}
  {% else %}
    {% assign hero_img = 'https://munler.co.uk/cdn/shop/files/ayna_cercevesini_champagne_gold_yap_202605251429.jpg' %}
{% endcase %}
{% render 'page-hero', img: hero_img, title: policy.title %}

<section class="warranty-body">
  <div class="container-narrow">
    <p class="policy-updated">Last updated: {{ 'now' | date: '%d %B %Y' }}</p>
    <div class="policy-section">
      {{ policy.body }}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var hero = document.querySelector('.warranty-hero');
  if (hero) {
    Object.assign(hero.style, {position:'relative',height:'90vh',minHeight:'560px',display:'flex',alignItems:'center',justifyContent:'center',textAlign:'center',overflow:'hidden'});
    var img = hero.querySelector('.warranty-hero-img');
    if (img) Object.assign(img.style, {position:'absolute',inset:'0',width:'100%',height:'100%',objectFit:'cover',objectPosition:'center'});
    var overlay = hero.querySelector('.warranty-hero-overlay');
    if (overlay) Object.assign(overlay.style, {position:'absolute',inset:'0',background:'linear-gradient(to bottom,rgba(10,10,10,.55),rgba(10,10,10,.45))'});
    var content = hero.querySelector('.warranty-hero-content');
    if (content) Object.assign(content.style, {position:'relative',zIndex:'2',padding:'0 24px',maxWidth:'680px'});
    var title = hero.querySelector('.warranty-hero-title');
    if (title) Object.assign(title.style, {fontFamily:'"Cormorant Garamond",serif',fontSize:'clamp(3.5rem,7vw,6.5rem)',fontWeight:'400',color:'#fff',lineHeight:'1.05'});
  }
  var section = document.querySelector('.policy-section');
  if (section) {
    section.querySelectorAll('h2').forEach(function(el) {
      el.style.setProperty('font-family', '"Cormorant Garamond", serif', 'important');
      el.style.setProperty('font-size', '1.6rem', 'important');
      el.style.setProperty('font-weight', '400', 'important');
      el.style.setProperty('color', '#1c1c1c', 'important');
      el.style.setProperty('line-height', '1.2', 'important');
      el.style.setProperty('margin-bottom', '1.2rem', 'important');
    });
    section.querySelectorAll('h3').forEach(function(el) {
      el.style.setProperty('font-family', '"Jost", sans-serif', 'important');
      el.style.setProperty('font-size', '0.75rem', 'important');
      el.style.setProperty('font-weight', '500', 'important');
      el.style.setProperty('letter-spacing', '0.1em', 'important');
      el.style.setProperty('text-transform', 'uppercase', 'important');
      el.style.setProperty('color', '#1c1c1c', 'important');
      el.style.setProperty('margin-bottom', '0.8rem', 'important');
      el.style.setProperty('margin-top', '1.8rem', 'important');
      el.style.setProperty('font-style', 'normal', 'important');
    });
    section.querySelectorAll('p').forEach(function(el) {
      el.style.setProperty('font-size', '0.88rem', 'important');
      el.style.setProperty('line-height', '1.9', 'important');
      el.style.setProperty('color', '#6b6b67', 'important');
      el.style.setProperty('margin-bottom', '1rem', 'important');
    });
    section.querySelectorAll('li').forEach(function(el) {
      el.style.setProperty('font-size', '0.88rem', 'important');
      el.style.setProperty('line-height', '1.85', 'important');
      el.style.setProperty('color', '#6b6b67', 'important');
    });
    section.querySelectorAll('a').forEach(function(el) {
      el.style.setProperty('color', '#1c1c1c', 'important');
      el.style.setProperty('text-decoration', 'underline', 'important');
    });
  }
});
</script>
