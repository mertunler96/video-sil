<style>
  .cart-page { padding: 8rem var(--gutter) 6rem; min-height: 60vh; }
  .cart-page h1 { font-family: var(--font-serif); font-size: clamp(2rem,4vw,3rem); font-weight: 300; margin-bottom: 3rem; }
  .cart-empty { text-align: center; padding: 4rem 0; border-top: 1px solid var(--color-border); }
  .cart-empty p { color: var(--color-mid); margin-bottom: 2rem; }

  .cart-col-headers { display: grid; grid-template-columns: 1fr auto auto; gap: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border); font-family: var(--font-sans); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-mid); }
  .cart-col-headers .col-qty { min-width: 132px; text-align: center; }
  .cart-col-headers .col-total { min-width: 80px; text-align: right; }

  .cart-item { display: grid; grid-template-columns: 100px 1fr; gap: 1.4rem; padding: 1.5rem 0; border-bottom: 1px solid var(--color-border); align-items: start; }
  .cart-item-img { display: block; width: 100px; height: 100px; object-fit: cover; }
  .cart-item-body { display: flex; flex-direction: column; gap: 0.35rem; }
  .cart-item-name { font-family: var(--font-serif); font-size: 1.05rem; color: var(--color-dark); text-decoration: none; }
  .cart-item-name:hover { text-decoration: underline; }
  .cart-item-variant { font-size: 0.8rem; color: var(--color-mid); }
  .cart-item-bottom { display: flex; align-items: center; gap: 1.2rem; margin-top: 0.8rem; flex-wrap: wrap; }
  .cart-item-price { font-family: var(--font-serif); font-size: 1.05rem; min-width: 80px; text-align: right; }

  .qty-control { display: flex; align-items: center; border: 1px solid var(--color-border); }
  .qty-btn { width: 44px; height: 44px; background: none; border: none; cursor: pointer; font-size: 1.1rem; color: var(--color-dark); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.15s; }
  .qty-btn:hover { background: var(--color-bg); }
  .qty-input { width: 44px; height: 44px; text-align: center; border: none; border-left: 1px solid var(--color-border); border-right: 1px solid var(--color-border); font-family: var(--font-sans); font-size: 0.9rem; background: none; -moz-appearance: textfield; }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .cart-remove { font-size: 0.78rem; color: var(--color-mid); background: none; border: none; cursor: pointer; padding: 0.5rem 0; text-decoration: underline; text-underline-offset: 2px; font-family: var(--font-sans); min-height: 44px; display: inline-flex; align-items: center; }
  .cart-remove:hover { color: var(--color-dark); }

  .cart-footer { margin-top: 2rem; display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; flex-wrap: wrap; }
  .cart-update-btn { background: none; border: 1px solid var(--color-border); padding: 0.9rem 1.6rem; font-family: var(--font-sans); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; color: var(--color-mid); min-height: 44px; }
  .cart-update-btn:hover { border-color: var(--color-dark); color: var(--color-dark); }
  .cart-summary { text-align: right; }
  .cart-summary-label { font-family: var(--font-sans); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-mid); margin-bottom: 0.5rem; }
  .cart-summary-total { font-family: var(--font-serif); font-size: 1.6rem; font-weight: 300; margin-bottom: 1.2rem; }
  .cart-summary-note { font-size: 0.78rem; color: var(--color-mid); margin-bottom: 1.2rem; }
  .cart-checkout-btn { display: inline-block; min-width: 220px; text-align: center; }

  @media (max-width: 600px) {
    .cart-col-headers { display: none; }
    .cart-item { grid-template-columns: 88px 1fr; gap: 1rem; }
    .cart-item-img { width: 88px; height: 88px; }
    .cart-item-bottom { gap: 0.8rem; }
    .cart-item-price { min-width: auto; text-align: left; }
    .cart-footer { flex-direction: column; align-items: stretch; }
    .cart-summary { text-align: left; }
    .cart-checkout-btn { display: block; min-width: 0; width: 100%; }
    .cart-update-btn { width: 100%; }
  }
</style>

<section class="cart-page">
  <div class="container-narrow">
    <h1>Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <p>Your cart is empty.</p>
        <a href="/collections/all" class="btn btn-dark">Continue Shopping</a>
      </div>
    {% else %}
      <form action="/cart" method="post" id="cart-form">
        <div class="cart-col-headers" aria-hidden="true">
          <span>Product</span>
          <span class="col-qty">Quantity</span>
          <span class="col-total">Total</span>
        </div>

        {% for item in cart.items %}
        <div class="cart-item">
          <a href="{{ item.url }}">
            <img src="{{ item.image | img_url: '200x200', crop: 'center' }}" alt="{{ item.title }}" class="cart-item-img" width="100" height="100">
          </a>
          <div class="cart-item-body">
            <a href="{{ item.url }}" class="cart-item-name">{{ item.product.title }}</a>
            {% unless item.variant.title == 'Default Title' %}
              {%- assign size_count = 0 -%}
              {%- for v in item.product.variants -%}
                {%- assign vt = v.title | downcase -%}
                {%- unless vt == 'default title' or vt contains 'gold' or vt contains 'black' or vt contains 'white' -%}
                  {%- assign size_count = size_count | plus: 1 -%}
                {%- endunless -%}
              {%- endfor -%}
              {%- assign size_name = '' -%}
              {%- if size_count == 2 -%}
                {%- assign size_idx = 0 -%}
                {%- for v in item.product.variants -%}
                  {%- assign vt = v.title | downcase -%}
                  {%- unless vt contains 'gold' or vt contains 'black' or vt contains 'white' -%}
                    {%- assign size_idx = size_idx | plus: 1 -%}
                    {%- if v.id == item.variant.id -%}
                      {%- if size_idx == 1 -%}{%- assign size_name = 'Medium' -%}{%- else -%}{%- assign size_name = 'Large' -%}{%- endif -%}
                    {%- endif -%}
                  {%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
              <span class="cart-item-variant">{% if size_name != '' %}{{ size_name }} · {% endif %}{{ item.variant.title }}</span>
            {% endunless %}
            <div class="cart-item-bottom">
              <div class="qty-control">
                <button type="button" class="qty-btn" aria-label="Decrease quantity">−</button>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="1" class="qty-input" aria-label="Quantity for {{ item.product.title }}">
                <button type="button" class="qty-btn" aria-label="Increase quantity">+</button>
              </div>
              <span class="cart-item-price">{{ item.line_price | money }}</span>
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-remove">Remove</a>
            </div>
          </div>
        </div>
        {% endfor %}

        <div class="cart-discount" style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--color-border);">
          <p style="font-family:var(--font-sans);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-dark);margin-bottom:0.8rem;">Discount Code</p>
          <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
            <input type="text" name="discount" id="cart-discount-input" placeholder="Enter code"
              style="flex:1;min-width:160px;padding:11px 14px;border:1px solid var(--color-border);font-family:var(--font-sans);font-size:0.82rem;background:none;color:var(--color-dark);outline:none;" autocomplete="off">
            <button type="button" id="apply-discount-btn" class="cart-update-btn" style="min-width:90px;">Apply</button>
          </div>
          <p id="discount-msg" style="font-size:0.75rem;color:var(--color-mid);margin-top:0.5rem;display:none;"></p>
        </div>

        <div class="cart-footer">
          <button type="submit" name="update" class="cart-update-btn">Update Cart</button>
          <div class="cart-summary">
            <p class="cart-summary-label">Subtotal</p>
            <p class="cart-summary-total">{{ cart.total_price | money }}</p>
            <p class="cart-summary-note">Shipping calculated at checkout.</p>
            <a href="/checkout" class="btn btn-dark cart-checkout-btn">Proceed to Checkout</a>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

<script>
(function(){
  document.querySelectorAll('.qty-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var input = btn.closest('.qty-control').querySelector('.qty-input');
      var val = parseInt(input.value, 10) || 1;
      btn.getAttribute('aria-label').indexOf('Increase') !== -1 ? input.value = val + 1 : (val > 1 && (input.value = val - 1));
    });
  });

  var discountBtn = document.getElementById('apply-discount-btn');
  var discountInput = document.getElementById('cart-discount-input');
  var discountMsg = document.getElementById('discount-msg');
  if (discountBtn && discountInput) {
    discountBtn.addEventListener('click', function(){
      var code = discountInput.value.trim();
      if (!code) return;
      fetch('/discount/' + encodeURIComponent(code), { method: 'GET', redirect: 'follow' })
        .then(function(r) {
          if (r.ok || r.redirected) {
            window.location.href = '/cart?discount=' + encodeURIComponent(code);
          } else {
            discountMsg.textContent = 'Invalid discount code.';
            discountMsg.style.display = 'block';
            discountMsg.style.color = '#c0392b';
          }
        })
        .catch(function(){
          window.location.href = '/cart?discount=' + encodeURIComponent(code);
        });
    });
    discountInput.addEventListener('keydown', function(e){
      if (e.key === 'Enter') discountBtn.click();
    });
  }
})();
</script>
