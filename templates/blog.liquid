{% render 'page-hero', img: 'https://munler.co.uk/cdn/shop/files/aynanin_tam_karsisindan_shot_ver__202605251536.jpg', title: blog.title %}

<style>
  .blog-body{padding:5rem var(--gutter) 6rem}
  .blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:3rem 2.4rem;max-width:1200px;margin:0 auto}
  .blog-card{display:flex;flex-direction:column}
  .blog-card-imgwrap{aspect-ratio:3/2;overflow:hidden;background:var(--color-light);margin-bottom:1.4rem}
  .blog-card-img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--ease-out)}
  .blog-card:hover .blog-card-img{transform:scale(1.04)}
  .blog-card-meta{font-family:var(--font-sans);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--color-gold);margin-bottom:.7rem}
  .blog-card-title{font-family:var(--font-serif);font-size:1.5rem;font-weight:400;line-height:1.25;margin-bottom:.8rem;color:var(--color-dark)}
  .blog-card:hover .blog-card-title{color:var(--color-gold)}
  .blog-card-excerpt{font-family:var(--font-sans);font-size:.9rem;font-weight:300;line-height:1.8;color:var(--color-mid);margin-bottom:1rem}
  .blog-card-link{font-family:var(--font-sans);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--color-dark);text-decoration:none;border-bottom:1px solid var(--color-dark);padding-bottom:3px;align-self:flex-start}
  .blog-empty{text-align:center;padding:5rem 0;color:var(--color-mid)}
</style>

<section class="blog-body">
  {% if blog.articles_count == 0 %}
    <p class="blog-empty">No articles published yet. Check back soon.</p>
  {% else %}
    {% paginate blog.articles by 9 %}
    <div class="blog-grid">
      {% for article in blog.articles %}
        <article class="blog-card">
          <a href="{{ article.url }}" class="blog-card-imgwrap" aria-label="{{ article.title | escape }}">
            {% if article.image %}
              <img src="{{ article.image | img_url: '600x' }}" alt="{{ article.image.alt | default: article.title }}" class="blog-card-img" width="600" height="400" loading="lazy">
            {% endif %}
          </a>
          <p class="blog-card-meta">{{ article.published_at | date: '%B %d, %Y' }}{% if article.tags.size > 0 %} · {{ article.tags.first }}{% endif %}</p>
          <h2 class="blog-card-title"><a href="{{ article.url }}" style="color:inherit;text-decoration:none">{{ article.title }}</a></h2>
          <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
          <a href="{{ article.url }}" class="blog-card-link">Read more</a>
        </article>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
    <div class="pagination" style="margin-top:4rem">
      {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="pagination-btn" aria-label="Previous page"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg></a>{% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}<a href="{{ part.url }}" class="pagination-num">{{ part.title }}</a>
        {% elsif part.title == paginate.current_page %}<span class="pagination-num is-current">{{ part.title }}</span>
        {% else %}<span class="pagination-ellipsis">{{ part.title }}</span>{% endif %}
      {% endfor %}
      {% if paginate.next %}<a href="{{ paginate.next.url }}" class="pagination-btn" aria-label="Next page"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg></a>{% endif %}
    </div>
    {% endif %}
    {% endpaginate %}
  {% endif %}
</section>
