{% comment %}Build product URL map by title matching — handles may vary{% endcomment %}
{% assign _url_brook_gold = '/collections/all' %}
{% assign _url_brook_black = '/collections/all' %}
{% assign _url_solenne = '/collections/all' %}
{% assign _url_rib = '/collections/all' %}
{% assign _url_volta = '/collections/all' %}
{% for _p in collections['all'].products %}
  {% assign _tl = _p.title | downcase %}
  {% if _tl contains 'brook' and _tl contains 'champagne' %}{% assign _url_brook_gold = _p.url %}{% endif %}
  {% if _tl contains 'brook' and _tl contains 'black' %}{% assign _url_brook_black = _p.url %}{% endif %}
  {% if _tl contains 'brook' and _tl contains 'matte' %}{% assign _url_brook_black = _p.url %}{% endif %}
  {% if _tl contains 'solenne' %}{% assign _url_solenne = _p.url %}{% endif %}
  {% if _tl contains 'rib' %}{% assign _url_rib = _p.url %}{% endif %}
  {% if _tl contains 'volta' %}{% assign _url_volta = _p.url %}{% endif %}
{% endfor %}

<!-- Hero Slider -->
<section class="hero" id="home">
  <div class="hero-slides">
    <div class="hero-slide is-active">
      <div class="hero-media">
        <video class="hero-video" autoplay muted loop playsinline>
          <source src="{{ 'hero.mp4' | asset_url }}" type="video/mp4">
        </video>
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <h1 class="hero-title">Crafted for<br><em>the Extraordinary</em></h1>
        <p class="hero-desc">Stainless steel frames &amp; ecological mirrors</p>
        <a href="#products" class="btn btn-light">Explore Collection</a>
      </div>
    </div>
    <div class="hero-slide">
      <div class="hero-media">
        <img src="https://munler.co.uk/cdn/shop/files/bu_odanin_farkli_shotlarini_ver__202605231515_91bb8878-aaa5-4548-a64a-2a5e1238b6b5.jpg" alt="MUNLER — The Brook Mirror in a modern living space" class="hero-img">
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <h1 class="hero-title">Crafted for<br><em>the Extraordinary</em></h1>
        <p class="hero-desc">Stainless steel frames &amp; ecological mirrors</p>
        <a href="#products" class="btn btn-light">Explore Collection</a>
      </div>
    </div>
  </div>
  <button class="hero-arrow hero-arrow--prev" aria-label="Previous slide">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="hero-arrow hero-arrow--next" aria-label="Next slide">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="hero-dots">
    <button class="hero-dot is-active" aria-label="Slide 1"></button>
    <button class="hero-dot" aria-label="Slide 2"></button>
  </div>
  <div class="hero-scroll"><span>Scroll</span><div class="scroll-line"></div></div>
</section>

<!-- Collections -->
<section class="collections" id="collections">
  <div class="collections-header">
    <span class="section-label">Our Collections</span>
    <h2>Define Your Space</h2>
  </div>
  <div class="collections-grid">
    <div class="collection-card reveal">
      <div class="collection-img-wrap">
        <img src="https://munler.co.uk/cdn/shop/files/aynaya_odakli_shotlar_ver_2K_202605251702.jpg" alt="MUNLER Mirror Collection">
      </div>
      <div class="collection-info">
        <span class="collection-num">01</span>
        <h3>Mirrors</h3>
        <a href="/collections/all#mirrors" class="link-arrow">Shop Collection <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
    <div class="collection-card reveal">
      <div class="collection-img-wrap">
        <img src="https://munler.co.uk/cdn/shop/files/Gemini_Generated_Image_f348e2f348e2f348.png" alt="MUNLER Furniture Collection">
      </div>
      <div class="collection-info">
        <span class="collection-num">02</span>
        <h3>Furniture</h3>
        <a href="/collections/all#furniture" class="link-arrow">Shop Collection <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
  </div>
</section>

<!-- Featured Products -->
<section class="products-section" id="products">
  <div class="container">
    <div class="section-header">
      <span class="section-label">The Edit</span>
      <h2>Our Signature Pieces</h2>
    </div>
    <div class="products-grid">
      {% assign fp_count = 0 %}
      {% for product in collections['all'].products %}
        {% if fp_count < 5 %}
          {% assign fp_count = fp_count | plus: 1 %}
          {% assign tags_lower = product.tags | join: ',' | downcase %}
          {% assign extra_class = '' %}
          {% if fp_count == 5 %}{% assign extra_class = ' product-card--wide' %}{% endif %}
          <article class="product-card{{ extra_class }} reveal" onclick="window.location='{{ product.url }}'" style="cursor:pointer">
            <div class="product-img-wrap">
              <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" class="product-img-main">
              {% if product.images[1] %}
                <img src="{{ product.images[1] | img_url: '800x' }}" alt="{{ product.title }}" class="product-img-hover">
              {% endif %}
              <div class="product-overlay"><a href="{{ product.url }}" class="btn-add-cart">View Product</a></div>
              {% if tags_lower contains 'new' %}<span class="product-badge">New</span>{% endif %}
              {% if tags_lower contains 'signature' %}<span class="product-badge product-badge--gold">Signature</span>{% endif %}
            </div>
            <div class="product-info">
              <div class="product-meta">
                {% if product.title contains '–' %}
                  <h3 class="product-name">{{ product.title | split: '–' | first | strip }}</h3>
                  <span class="product-variant">{{ product.title | split: '–' | last | strip }}</span>
                {% else %}
                  <h3 class="product-name">{{ product.title }}</h3>
                {% endif %}
              </div>
              <span class="product-price">{{ product.price | money_without_trailing_zeros }}</span>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
    <div class="products-cta">
      <a href="/collections/all" class="btn btn-dark">View All Products</a>
    </div>
  </div>
</section>

<!-- Values -->
<section class="values">
  <div class="container">
    <div class="values-grid">
      <div class="value-item reveal">
        <div class="value-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h4>Ecological Materials</h4>
        <p>Our mirrors are crafted using sustainable, ecological glass — designed to reduce environmental impact without compromising clarity or quality.</p>
      </div>
      <div class="value-item reveal">
        <div class="value-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
        <h4>Premium Stainless Steel</h4>
        <p>Each frame is precision-engineered in premium stainless steel — resistant to corrosion, tarnish, and time. Built to last a lifetime.</p>
      </div>
      <div class="value-item reveal">
        <div class="value-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
        <h4>Free UK Delivery</h4>
        <p>Every order over £150 includes complimentary UK delivery. Your piece arrives safely packaged and ready to transform your space.</p>
      </div>
      <div class="value-item reveal">
        <div class="value-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
        <h4>5-Year Warranty</h4>
        <p>Every MUNLER piece is backed by a 5-year warranty against manufacturing defects — a reflection of the confidence we have in our materials and craft.</p>
      </div>
    </div>
  </div>
</section>

