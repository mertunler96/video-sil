<section class="page-hero">
  <span class="section-label" style="color: var(--color-gold);">
    {% if collection.handle == 'all' %}All Products{% else %}The Collection{% endif %}
  </span>
  <h1 class="page-hero-title">
    {% if collection.handle == 'all' %}Shop All{% else %}{{ collection.title }}{% endif %}
  </h1>
  {% if collection.description != blank %}
    <p class="page-hero-desc">{{ collection.description | strip_html }}</p>
  {% endif %}
</section>

<section style="padding: 5rem 0 8rem; background: var(--color-bg);">
  <div class="container">
    {% if collection.products.size == 0 %}
      <div style="text-align:center; padding: 6rem 0;">
        <p style="color: var(--color-mid); font-size: 0.95rem; margin-bottom: 2rem;">No products found in this collection.</p>
        <a href="/collections/all" class="btn btn-dark">View All Products</a>
      </div>
    {% else %}
      <div class="products-grid">
        {% for product in collection.products %}
          <article class="product-card reveal" onclick="window.location='/products/{{ product.handle }}'" style="cursor:pointer">
            <div class="product-img-wrap">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" class="product-img-main">
              {% endif %}
              {% if product.images[1] %}
                <img src="{{ product.images[1] | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" class="product-img-hover">
              {% endif %}
              <div class="product-overlay">
                <a href="/products/{{ product.handle }}" class="btn-add-cart">View Product</a>
              </div>
              {% if product.tags contains 'new' %}<span class="product-badge">New</span>{% endif %}
              {% if product.tags contains 'signature' %}<span class="product-badge product-badge--gold">Signature</span>{% endif %}
            </div>
            <div class="product-info">
              <div class="product-meta">
                <h3 class="product-name">{{ product.title }}</h3>
                {% if product.variants.size > 1 %}
                  <span class="product-variant">{{ product.variants.size }} options</span>
                {% endif %}
              </div>
              <span class="product-price">{{ product.price | money }}</span>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
