<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "image": [{% if article.image %}"https:{{ article.image | img_url: '1200x' }}"{% else %}"{{ shop.url }}"{% endif %}],
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": { "@type": "Organization", "name": "MUNLER" },
  "publisher": {
    "@type": "Organization",
    "name": "MUNLER",
    "url": "{{ shop.url }}"
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ shop.url }}{{ article.url }}" },
  "description": {{ article.excerpt_or_content | strip_html | truncate: 200 | json }}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":{{ blog.title | json }},"item":"{{ shop.url }}{{ blog.url }}"},
    {"@type":"ListItem","position":3,"name":{{ article.title | json }},"item":"{{ shop.url }}{{ article.url }}"}
  ]
}
</script>

<style>
  .article-head{padding:calc(var(--header-h) + 34px + 4rem) var(--gutter) 2.5rem;text-align:center;max-width:760px;margin:0 auto}
  .article-meta{font-family:var(--font-sans);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--color-gold);margin-bottom:1.2rem}
  .article-title{font-family:var(--font-serif);font-size:clamp(2.2rem,5vw,3.6rem);font-weight:400;line-height:1.1;color:var(--color-dark)}
  .article-hero-img{display:block;width:auto;max-width:min(100%,720px);max-height:90vh;height:auto;margin:1rem auto 3.5rem}
  .article-body{max-width:720px;margin:0 auto;padding:0 var(--gutter) 4rem}
  .article-body p,.article-body li{font-family:var(--font-sans);font-size:1rem;font-weight:300;line-height:1.95;color:#444;margin-bottom:1.3rem}
  .article-body h2{font-family:var(--font-serif);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;margin:2.8rem 0 1rem;line-height:1.2}
  .article-body h3{font-family:var(--font-serif);font-size:1.35rem;font-weight:400;margin:2rem 0 .8rem}
  .article-body figure{margin:2.4rem 0}
  .article-body img{display:block;max-width:100%;width:auto;max-height:760px;height:auto;margin:0 auto}
  .article-body figcaption{margin-top:.7rem;text-align:center;font-family:var(--font-sans);font-size:.78rem;font-weight:300;letter-spacing:.02em;color:var(--color-mid)}
  .article-body a{color:var(--color-gold);text-decoration:underline;text-underline-offset:3px}
  .article-body ul,.article-body ol{padding-left:1.3rem;margin-bottom:1.3rem}
  .article-cta{text-align:center;padding:3.5rem var(--gutter) 6rem;border-top:1px solid var(--color-border);max-width:720px;margin:0 auto}
  .article-cta p{font-family:var(--font-serif);font-size:1.5rem;font-weight:400;margin-bottom:1.6rem}
  .article-back{display:inline-block;margin:0 var(--gutter) 4rem;font-family:var(--font-sans);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--color-mid);text-decoration:none}
  .article-back:hover{color:var(--color-gold)}
</style>

<article>
  <header class="article-head">
    <p class="article-meta">{{ article.published_at | date: '%B %d, %Y' }}{% if article.tags.size > 0 %} · {{ article.tags.first }}{% endif %}</p>
    <h1 class="article-title">{{ article.title }}</h1>
  </header>

  {% if article.image %}
    <img src="{{ article.image | img_url: '1200x' }}" alt="{{ article.image.alt | default: article.title }}" class="article-hero-img" loading="eager">
  {% endif %}

  <div class="article-body rte">
    {{ article.content }}
  </div>

  <div class="article-cta">
    <p>Bring the look home.</p>
    <a href="/collections/all" class="btn btn-dark">Shop the Collection</a>
  </div>
</article>

<a href="{{ blog.url }}" class="article-back">← Back to {{ blog.title }}</a>

{% if blog.comments_enabled? %}
<section class="article-body" style="padding-top:0">
  {% if article.comments_count > 0 %}
    <h2 style="font-family:var(--font-serif);font-weight:400;margin-bottom:1.5rem">Comments ({{ article.comments_count }})</h2>
    {% for comment in article.comments %}
      <div style="border-top:1px solid var(--color-border);padding:1.5rem 0">
        <p style="margin-bottom:.4rem">{{ comment.content }}</p>
        <p style="font-size:.8rem;color:var(--color-mid)">— {{ comment.author }}</p>
      </div>
    {% endfor %}
  {% endif %}
</section>
{% endif %}
