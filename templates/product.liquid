  <!-- Related Products -->
  <section class="related-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">You May Also Like</span>
        <h2>More from MUNLER</h2>
      </div>
      <div class="related-grid">
        {% assign rel_count = 0 %}
        {% for p in collections['all'].products %}
          {% if p.handle != product.handle and rel_count < 3 %}
            {% assign rel_count = rel_count | plus: 1 %}
            <article class="product-card reveal" onclick="window.location='{{ p.url }}'" style="cursor:pointer">
              <div class="product-img-wrap">
                <img src="{{ p.featured_image | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-main">
                {% if p.images[1] %}<img src="{{ p.images[1] | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-hover">{% endif %}
                <div class="product-overlay"><a href="{{ p.url }}" class="btn-add-cart">View Product</a></div>
                {% assign p_tags_lower = p.tags | join: ',' | downcase %}
                {% if p_tags_lower contains 'signature' or p.title contains 'Solenne' %}<span class="product-badge product-badge--gold">Signature</span>{% endif %}
                {% if p_tags_lower contains 'new' %}<span class="product-badge">New</span>{% endif %}
              </div>
              <div class="product-info">
                <div class="product-meta">
                  {% if p.title contains '–' %}
                    <h3 class="product-name">{{ p.title | split: '–' | first | strip }}</h3>
                    <span class="product-variant">{{ p.title | split: '–' | last | strip }}</span>
                  {% else %}
                    <h3 class="product-name">{{ p.title }}</h3>
                  {% endif %}
                </div>
                <span class="product-price">{{ p.price | money_without_trailing_zeros }}</span>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</main>

<!-- Sticky mobile ATC bar -->
<div class="sticky-atc-bar" id="sticky-atc-bar" aria-hidden="true">
  <div class="sticky-atc-info">
    <span class="sticky-atc-name">{% if product.title contains '–' %}{{ product.title | split: '–' | first | strip }}{% else %}{{ product.title }}{% endif %}</span>
    <span class="sticky-atc-price" id="sticky-atc-price">{{ product.selected_or_first_available_variant.price | money }}</span>
  </div>
  <button type="button" class="sticky-atc-btn" id="sticky-atc-btn">Add to Cart</button>
</div>

<script>
(function(){
  'use strict';

  // Build image array from thumbnail data-src attributes
  var thumbBtns = document.querySelectorAll('.thumb');
  var images    = Array.from(thumbBtns).map(function(btn){ return btn.getAttribute('data-src'); });
  var currentIndex = 0;
  var isAnimating  = false;
  var mainImg      = document.getElementById('gallery-main-img');
  var dots         = document.querySelectorAll('.dot');

  // Preload all images upfront for smooth transitions
  images.forEach(function(src){ var i = new Image(); i.src = src; });

  // Slide animation — direction: 1=next, -1=prev, 0=direct
  function goTo(index, direction) {
    if (isAnimating) return;
    if (index < 0) index = images.length - 1;
    if (index >= images.length) index = 0;
    if (index === currentIndex) return;
    isAnimating = true;

    var exitX  = direction > 0 ? '-40px' : direction < 0 ? '40px' : '0px';
    var enterX = direction > 0 ? '40px'  : direction < 0 ? '-40px' : '0px';

    mainImg.style.transition = 'opacity 0.28s ease, transform 0.28s ease';
    mainImg.style.opacity    = '0';
    mainImg.style.transform  = 'translateX(' + exitX + ')';

    setTimeout(function(){
      mainImg.src = images[index];
      mainImg.removeAttribute('srcset');
      currentIndex = index;

      mainImg.style.transition = 'none';
      mainImg.style.transform  = 'translateX(' + enterX + ')';
      mainImg.style.opacity    = '0';

      void mainImg.offsetWidth; // force repaint

      mainImg.style.transition = 'opacity 0.32s ease, transform 0.32s ease';
      mainImg.style.opacity    = '1';
      mainImg.style.transform  = 'translateX(0)';

      thumbBtns.forEach(function(btn,i){ btn.classList.toggle('active', i===index); });
      dots.forEach(function(dot,i){ dot.classList.toggle('active', i===index); });

      setTimeout(function(){ isAnimating = false; }, 350);
    }, 290);
  }

  // Thumbnail clicks
  thumbBtns.forEach(function(btn, i){
    btn.addEventListener('click', function(){
      goTo(i, i > currentIndex ? 1 : -1);
    });
  });

  // Dot clicks
  dots.forEach(function(dot, i){
    dot.addEventListener('click', function(){
      goTo(i, i > currentIndex ? 1 : -1);
    });
  });

  // Arrow buttons
  var prevBtn = document.getElementById('gallery-prev');
  var nextBtn = document.getElementById('gallery-next');
  if (prevBtn) prevBtn.addEventListener('click', function(){ goTo(currentIndex - 1, -1); });
  if (nextBtn) nextBtn.addEventListener('click', function(){ goTo(currentIndex + 1,  1); });

  // Touch swipe
  var touchStartX = 0;
  var mainWrap = document.querySelector('.gallery-main-wrap');
  if (mainWrap) {
    mainWrap.addEventListener('touchstart', function(e){ touchStartX = e.changedTouches[0].clientX; }, { passive: true });
    mainWrap.addEventListener('touchend', function(e){
      var diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(diff > 0 ? currentIndex + 1 : currentIndex - 1, diff > 0 ? 1 : -1);
    }, { passive: true });
  }

  // Size selector + price update
  document.querySelectorAll('.size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      document.getElementById('variant-id').value = btn.getAttribute('data-variant-id');
      var priceEl = document.getElementById('pinfo-price');
      if (priceEl) priceEl.textContent = btn.getAttribute('data-price');
      var sizeLabel = document.getElementById('selected-size-label');
      if (sizeLabel) sizeLabel.textContent = btn.getAttribute('data-title');
    });
  });

  // Accordions
  document.querySelectorAll('.accordion-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var acc = btn.closest('.accordion');
      var isOpen = acc.classList.contains('open');
      document.querySelectorAll('.accordion').forEach(function(a){
        a.classList.remove('open');
        a.querySelector('.accordion-btn').setAttribute('aria-expanded','false');
      });
      if (!isOpen) { acc.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
    });
  });

  // Quantity selector
  document.querySelectorAll('.qty-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var input = btn.closest('.qty-control').querySelector('.qty-input');
      var val = parseInt(input.value, 10) || 1;
      if (btn.classList.contains('qty-plus')) {
        input.value = val + 1;
      } else if (val > 1) {
        input.value = val - 1;
      }
    });
  });

  // Wishlist with localStorage
  var wishBtn = document.querySelector('.btn-wishlist');
  if (wishBtn) {
    var pid = wishBtn.getAttribute('data-product-id');
    var wishlist = JSON.parse(localStorage.getItem('munler_wishlist') || '[]');
    if (pid && wishlist.indexOf(pid) > -1) wishBtn.classList.add('saved');
    wishBtn.addEventListener('click', function(){
      wishBtn.classList.toggle('saved');
      var list = JSON.parse(localStorage.getItem('munler_wishlist') || '[]');
      var saved = wishBtn.classList.contains('saved');
      var idx = list.indexOf(pid);
      if (saved && idx === -1) list.push(pid);
      else if (!saved && idx > -1) list.splice(idx, 1);
      localStorage.setItem('munler_wishlist', JSON.stringify(list));
    });
  }

  // Sticky ATC bar — show when original ATC scrolls out of view
  var stickyBar = document.getElementById('sticky-atc-bar');
  var atcBtn    = document.querySelector('.btn-atc');
  var stickyBtn = document.getElementById('sticky-atc-btn');
  var stickyPriceEl = document.getElementById('sticky-atc-price');
  if (stickyBar && atcBtn) {
    var atcObserver = new IntersectionObserver(function(entries){
      var visible = entries[0].isIntersecting;
      stickyBar.classList.toggle('is-visible', !visible);
      stickyBar.setAttribute('aria-hidden', visible ? 'true' : 'false');
    }, { threshold: 0 });
    atcObserver.observe(atcBtn);
    if (stickyBtn) {
      stickyBtn.addEventListener('click', function(){
        document.querySelector('form[action="/cart/add"]') ? document.querySelector('form[action="/cart/add"]').querySelector('[name="add"]').click() : atcBtn.click();
      });
    }
  }

  // Sync sticky price with variant changes
  document.querySelectorAll('.size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      if (stickyPriceEl) stickyPriceEl.textContent = btn.getAttribute('data-price');
    });
  });

})();
</script>
