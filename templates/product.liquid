{% assign variant_prices = '' %}
{% for v in product.variants %}
  {% assign variant_prices = variant_prices | append: v.id | append: ':' | append: v.price | append: ',' %}
{% endfor %}

<main class="product-main">

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="bc-sep">/</span>
        <a href="/collections/all">Shop</a>
        <span class="bc-sep">/</span>
        <span>{% if product.title contains '–' %}{{ product.title | split: '–' | first | strip }}{% else %}{{ product.title }}{% endif %}</span>
      </nav>
    </div>
  </div>

  <!-- Product Layout -->
  <section class="product-section">
    <div class="product-layout container">

      <!-- Gallery -->
      <div class="product-gallery" id="product-gallery">
        <div class="gallery-thumbs" id="gallery-thumbs">
          {% for image in product.images %}
            <button class="thumb {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" data-src="{{ image | img_url: '1000x' }}" onclick="galleryGoTo({{ forloop.index0 }})">
              <img src="{{ image | img_url: '120x' }}" alt="{{ image.alt | default: product.title }}">
            </button>
          {% endfor %}
        </div>

        <div class="gallery-main-wrap">
          <button class="gallery-arrow gallery-arrow--prev" onclick="galleryStep(-1)" aria-label="Previous image">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="gallery-main" id="gallery-main">
            <img src="{{ product.featured_image | img_url: '1000x' }}" alt="{{ product.title }}" id="gallery-main-img">
          </div>
          <button class="gallery-arrow gallery-arrow--next" onclick="galleryStep(1)" aria-label="Next image">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
          <div class="gallery-dots" id="gallery-dots">
            {% for image in product.images %}
              <span class="dot {% if forloop.first %}active{% endif %}" onclick="galleryGoTo({{ forloop.index0 }})"></span>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info-col">
        <div class="product-info-sticky">

          <div class="pinfo-header">
            {% if product.title contains '–' %}
              <span class="pinfo-collection">{{ product.title | split: '–' | last | strip }}</span>
              <h1 class="pinfo-title">{{ product.title | split: '–' | first | strip }}</h1>
            {% else %}
              <h1 class="pinfo-title">{{ product.title }}</h1>
            {% endif %}
            {% if product.metafields.custom.tagline %}
              <p class="pinfo-tagline">{{ product.metafields.custom.tagline }}</p>
            {% endif %}
          </div>

          <div class="pinfo-price-block">
            <span class="pinfo-price" id="pinfo-price">{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</span>
            <span class="pinfo-price-note">Inc. VAT · Free UK delivery over £150</span>
          </div>

          {% form 'product', product %}
            {% assign size_variants = product.variants | where: 'available', true %}
            {% assign has_sizes = false %}
            {% for v in product.variants %}
              {% assign vt = v.title | downcase %}
              {% unless vt == 'default title' or vt contains 'gold' or vt contains 'black' or vt contains 'white' %}
                {% assign has_sizes = true %}
              {% endunless %}
            {% endfor %}

            {% if has_sizes %}
            <div class="option-group">
              <div class="option-label-row">
                <span class="option-label">Size</span>
                <span class="option-selected-val" id="selected-size-label">{{ product.selected_or_first_available_variant.title }}</span>
              </div>
              <div class="size-options">
                {% for variant in product.variants %}
                  {% assign vt = variant.title | downcase %}
                  {% unless vt contains 'gold' or vt contains 'black' or vt contains 'white' %}
                    {% assign parts = variant.title | split: ' - ' %}
                    <button type="button" class="size-btn {% if variant == product.selected_or_first_available_variant %}active{% endif %}"
                      data-variant-id="{{ variant.id }}"
                      data-price="{{ variant.price | money_without_trailing_zeros }}"
                      data-title="{{ variant.title }}"
                      {% unless variant.available %}disabled{% endunless %}>
                      <span class="size-cm">{{ parts[0] }}</span>
                      {% if parts[1] %}<span class="size-in">{{ parts[1] }}</span>{% endif %}
                    </button>
                  {% endunless %}
                {% endfor %}
              </div>
            </div>
            {% endif %}

            <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="quantity" value="1">

            <div class="pinfo-actions">
              <button type="submit" name="add" class="btn-atc" {% unless product.available %}disabled{% endunless %}>
                <span class="btn-atc-text">{% if product.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </button>
              <button type="button" class="btn-wishlist" aria-label="Save to wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            </div>
          {% endform %}

          <div class="trust-badges">
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg><span>Free UK Delivery</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Fully Insured</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span>Tracked Shipping</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span>Ships in 3–5 Days</span></div>
          </div>

          <div class="accordions">
            <div class="accordion open">
              <button class="accordion-btn" aria-expanded="true">
                <span>Description</span>
                <svg class="accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="accordion-body">
                {{ product.description }}
              </div>
            </div>
            <div class="accordion">
              <button class="accordion-btn" aria-expanded="false">
                <span>Delivery &amp; Returns</span>
                <svg class="accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="accordion-body">
                <ul class="detail-list">
                  <li>Dispatched within 3–5 business days</li>
                  <li>Fully tracked and insured UK delivery</li>
                  <li>Free delivery on orders over £150</li>
                  <li>30-day returns — <a href="/pages/shipping-returns">full policy</a></li>
                </ul>
              </div>
            </div>
            <div class="accordion">
              <button class="accordion-btn" aria-expanded="false">
                <span>Warranty</span>
                <svg class="accordion-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="accordion-body">
                <ul class="detail-list">
                  <li>5-year warranty against manufacturing defects</li>
                  <li>Covers frame corrosion and structural failure</li>
                  <li><a href="/pages/warranty">View full warranty terms</a></li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- Related Products -->
  <section class="related-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">You May Also Like</span>
        <h2>More from MUNLER</h2>
      </div>
      <div class="related-grid">
        {% assign rel_count = 0 %}
        {% for p in collections['all'].products %}
          {% if p.handle != product.handle and rel_count < 3 %}
            {% assign rel_count = rel_count | plus: 1 %}
            <article class="product-card reveal" onclick="window.location='{{ p.url }}'" style="cursor:pointer">
              <div class="product-img-wrap">
                <img src="{{ p.featured_image | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-main">
                {% if p.images[1] %}<img src="{{ p.images[1] | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-hover">{% endif %}
                <div class="product-overlay"><a href="{{ p.url }}" class="btn-add-cart">View Product</a></div>
              </div>
              <div class="product-info">
                <div class="product-meta">
                  {% if p.title contains '–' %}
                    <h3 class="product-name">{{ p.title | split: '–' | first | strip }}</h3>
                    <span class="product-variant">{{ p.title | split: '–' | last | strip }}</span>
                  {% else %}
                    <h3 class="product-name">{{ p.title }}</h3>
                  {% endif %}
                </div>
                <span class="product-price">{{ p.price | money_without_trailing_zeros }}</span>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</main>

<script>
(function(){
  var images = [{% for img in product.images %}'{{ img | img_url: '1000x' }}'{% unless forloop.last %},{% endunless %}{% endfor %}];
  var currentIdx = 0;

  function galleryGoTo(idx) {
    currentIdx = idx;
    var mainImg = document.getElementById('gallery-main-img');
    if(mainImg) mainImg.src = images[idx];
    document.querySelectorAll('.thumb').forEach(function(t,i){ t.classList.toggle('active', i===idx); });
    document.querySelectorAll('.dot').forEach(function(d,i){ d.classList.toggle('active', i===idx); });
  }

  window.galleryGoTo = galleryGoTo;
  window.galleryStep = function(dir) {
    galleryGoTo((currentIdx + dir + images.length) % images.length);
  };

  // Size selector + price update
  document.querySelectorAll('.size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var vid = btn.getAttribute('data-variant-id');
      var price = btn.getAttribute('data-price');
      var title = btn.getAttribute('data-title');
      document.getElementById('variant-id').value = vid;
      var priceEl = document.getElementById('pinfo-price');
      if(priceEl) priceEl.textContent = price;
      var sizeLabel = document.getElementById('selected-size-label');
      if(sizeLabel) sizeLabel.textContent = title;
    });
  });

  // Accordions
  document.querySelectorAll('.accordion-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var acc = btn.closest('.accordion');
      acc.classList.toggle('open');
      btn.setAttribute('aria-expanded', acc.classList.contains('open'));
    });
  });
})();
</script>
