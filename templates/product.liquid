  <!-- Related Products -->
  <section class="related-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">You May Also Like</span>
        <h2>More from MUNLER</h2>
      </div>
      <div class="related-grid">
        {% assign rel_count = 0 %}
        {% for p in collections['all'].products %}
          {% if p.handle != product.handle and rel_count < 3 %}
            {% assign rel_count = rel_count | plus: 1 %}
            <article class="product-card reveal" onclick="window.location='{{ p.url }}'" style="cursor:pointer">
              <div class="product-img-wrap">
                <img src="{{ p.featured_image | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-main">
                {% if p.images[1] %}<img src="{{ p.images[1] | img_url: '800x' }}" alt="{{ p.title }}" class="product-img-hover">{% endif %}
                <div class="product-overlay"><a href="{{ p.url }}" class="btn-add-cart">View Product</a></div>
              </div>
              <div class="product-info">
                <div class="product-meta">
                  {% if p.title contains '–' %}
                    <h3 class="product-name">{{ p.title | split: '–' | first | strip }}</h3>
                    <span class="product-variant">{{ p.title | split: '–' | last | strip }}</span>
                  {% else %}
                    <h3 class="product-name">{{ p.title }}</h3>
                  {% endif %}
                </div>
                <span class="product-price">{{ p.price | money_without_trailing_zeros }}</span>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</main>

<script>
(function(){
  var images = [{% for img in product.images %}'{{ img | img_url: '1000x' }}'{% unless forloop.last %},{% endunless %}{% endfor %}];
  var currentIdx = 0;

  function galleryGoTo(idx) {
    currentIdx = idx;
    var mainImg = document.getElementById('gallery-main-img');
    if(mainImg) {
      mainImg.style.opacity = '0';
      var preload = new Image();
      preload.onload = function() {
        mainImg.src = images[idx];
        mainImg.style.opacity = '1';
      };
      preload.src = images[idx];
      // fallback if cached
      if(preload.complete) { mainImg.src = images[idx]; mainImg.style.opacity = '1'; }
    }
    document.querySelectorAll('.thumb').forEach(function(t,i){ t.classList.toggle('active', i===idx); });
    document.querySelectorAll('.dot').forEach(function(d,i){ d.classList.toggle('active', i===idx); });
  }

  window.galleryGoTo = galleryGoTo;
  window.galleryStep = function(dir) {
    galleryGoTo((currentIdx + dir + images.length) % images.length);
  };

  // Size selector + price update
  document.querySelectorAll('.size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.size-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var vid = btn.getAttribute('data-variant-id');
      var price = btn.getAttribute('data-price');
      var title = btn.getAttribute('data-title');
      document.getElementById('variant-id').value = vid;
      var priceEl = document.getElementById('pinfo-price');
      if(priceEl) priceEl.textContent = price;
      var sizeLabel = document.getElementById('selected-size-label');
      if(sizeLabel) sizeLabel.textContent = title;
    });
  });

  // Accordions
  document.querySelectorAll('.accordion-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var acc = btn.closest('.accordion');
      acc.classList.toggle('open');
      btn.setAttribute('aria-expanded', acc.classList.contains('open'));
    });
  });
})();
</script>
