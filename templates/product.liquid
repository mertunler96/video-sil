{% assign variant_prices = '' %}
{% for v in product.variants %}
  {% assign variant_prices = variant_prices | append: v.id | append: ':' | append: v.price | append: ',' %}
{% endfor %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "image": [{% for image in product.images %}"{{ image | img_url: '1000x' }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
  "brand": {
    "@type": "Brand",
    "name": "MUNLER"
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "GBP",
    "lowPrice": "{{ product.price_min | money_without_currency }}",
    "highPrice": "{{ product.price_max | money_without_currency }}",
    "offerCount": {{ product.variants.size }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":"Shop","item":"{{ shop.url }}/collections/all"},
    {"@type":"ListItem","position":3,"name":{{ product.title | json }},"item":"{{ shop.url }}{{ product.url }}"}
  ]
}
</script>

<main class="product-main">

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="bc-sep">/</span>
        <a href="/collections/all">Shop</a>
        <span class="bc-sep">/</span>
        <span>{% if product.title contains '–' %}{{ product.title | split: '–' | first | strip }}{% else %}{{ product.title }}{% endif %}</span>
      </nav>
    </div>
  </div>

  <!-- Product Layout -->
  <section class="product-section">
    <div class="product-layout container">

      <!-- Gallery -->
      <div class="product-gallery" id="product-gallery">
        <div class="gallery-thumbs" id="gallery-thumbs">
          {% for image in product.images %}
            <button class="thumb {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" data-src="{{ image | img_url: '1000x' }}">
              <img src="{{ image | img_url: '120x' }}" alt="{{ image.alt | default: product.title }}">
            </button>
          {% endfor %}
        </div>

        <div class="gallery-main-wrap">
          <button class="gallery-arrow gallery-arrow--prev" id="gallery-prev" aria-label="Previous image">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="gallery-main" id="gallery-main">
            <img src="{{ product.featured_image | img_url: '1000x' }}"
                 srcset="{{ product.featured_image | img_url: '480x' }} 480w, {{ product.featured_image | img_url: '800x' }} 800w, {{ product.featured_image | img_url: '1000x' }} 1000w"
                 sizes="(max-width: 900px) 100vw, 55vw"
                 alt="{{ product.title }}"
                 width="800" height="1067"
                 id="gallery-main-img">
          </div>
          <button class="gallery-arrow gallery-arrow--next" id="gallery-next" aria-label="Next image">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
          <div class="gallery-dots" id="gallery-dots">
            {% for image in product.images %}
              <span class="dot {% if forloop.first %}active{% endif %}"></span>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info-col">
        <div class="product-info-sticky">

          {% assign tl = product.title | downcase %}
          <div class="pinfo-header">
            {% if tl contains 'brook' and tl contains 'champagne' %}
              <span class="pinfo-collection">Mirrors — Champagne Gold</span>
              <h1 class="pinfo-title">The Brook Mirror</h1>
              <p class="pinfo-tagline">An architectural focal point, crafted for lasting beauty and unparalleled clarity.</p>
            {% elsif tl contains 'brook' and tl contains 'black' or tl contains 'brook' and tl contains 'matte' %}
              <span class="pinfo-collection">Mirrors — Matte Black</span>
              <h1 class="pinfo-title">The Brook Mirror</h1>
              <p class="pinfo-tagline">Bold, modern elegance meets industrial-grade precision. A statement in any space.</p>
            {% elsif tl contains 'solenne' %}
              <span class="pinfo-collection">Mirrors — Signature Collection</span>
              <h1 class="pinfo-title">The Solenne Mirror</h1>
              <p class="pinfo-tagline">An oversized, organic silhouette that transforms any room into a gallery. Hand-crafted in small batches.</p>
            {% elsif tl contains 'rib' %}
              <span class="pinfo-collection">Furniture — The Base Edit</span>
              <h1 class="pinfo-title">The Rib End Table</h1>
              <p class="pinfo-tagline">A hand-carved fluted column in solid hardwood. Classical form, stripped of ornament, built for the contemporary home.</p>
            {% elsif tl contains 'volta' %}
              <span class="pinfo-collection">Furniture — The Base Edit</span>
              <h1 class="pinfo-title">The Volta End Table</h1>
              <p class="pinfo-tagline">Architectural detail meets natural material. Each piece is unique — no two marble tops are ever identical.</p>
            {% else %}
              {% if product.title contains '–' %}
                <span class="pinfo-collection">{{ product.title | split: '–' | last | strip }}</span>
                <h1 class="pinfo-title">{{ product.title | split: '–' | first | strip }}</h1>
              {% else %}
                <h1 class="pinfo-title">{{ product.title }}</h1>
              {% endif %}
            {% endif %}
          </div>

          <div class="pinfo-price-block">
            <span class="pinfo-price" id="pinfo-price">{{ product.selected_or_first_available_variant.price | money }}</span>
            <span class="pinfo-price-note">Inc. VAT · Free UK delivery over £150</span>
          </div>

          {% form 'product', product %}
            {% comment %}Count selectable size variants (exclude colour names and single/default){% endcomment %}
            {% assign size_count = 0 %}
            {% for v in product.variants %}
              {% assign vt = v.title | downcase %}
              {% unless vt == 'default title' or vt contains 'gold' or vt contains 'black' or vt contains 'white' %}
                {% assign size_count = size_count | plus: 1 %}
              {% endunless %}
            {% endfor %}

            {% if size_count > 1 %}
            <div class="option-group">
              <div class="option-label-row">
                <span class="option-label">Size</span>
                <span class="option-selected-val" id="selected-size-label">{{ product.selected_or_first_available_variant.title }}</span>
              </div>
              <div class="size-options">
                {% for variant in product.variants %}
                  {% assign vt = variant.title | downcase %}
                  {% unless vt contains 'gold' or vt contains 'black' or vt contains 'white' %}
                    {% assign parts = variant.title | split: ' - ' %}
                    <button type="button" class="size-btn {% if variant == product.selected_or_first_available_variant %}active{% endif %}"
                      data-variant-id="{{ variant.id }}"
                      data-price="{{ variant.price | money }}"
                      data-title="{{ variant.title }}"
                      {% unless variant.available %}disabled{% endunless %}>
                      <span class="size-cm">{{ parts[0] }}</span>
                      {% if parts[1] %}<span class="size-in">{{ parts[1] }}</span>{% endif %}
                    </button>
                  {% endunless %}
                {% endfor %}
              </div>
            </div>
            {% elsif size_count == 1 %}
            {% for variant in product.variants %}
              {% assign vt = variant.title | downcase %}
              {% unless vt contains 'gold' or vt contains 'black' or vt contains 'white' or vt == 'default title' %}
              <div class="option-group">
                <div class="option-label-row">
                  <span class="option-label">Dimensions</span>
                  <span class="option-selected-val">{{ variant.title }}</span>
                </div>
              </div>
              {% endunless %}
            {% endfor %}
            {% endif %}

            <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
            <div class="qty-group">
              <span class="option-label">Quantity</span>
              <div class="qty-control">
                <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">−</button>
                <input type="number" name="quantity" value="1" min="1" max="99" class="qty-input" id="product-qty" aria-label="Quantity">
                <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
              </div>
            </div>

            <div class="pinfo-actions">
              <button type="submit" name="add" class="btn-atc" {% unless product.available %}disabled{% endunless %}>
                <span class="btn-atc-text">{% if product.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </button>
              <button type="button" class="btn-wishlist" aria-label="Save to wishlist" data-product-id="{{ product.id }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            </div>
          {% endform %}

          <div class="trust-badges">
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg><span>Free UK Delivery</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Fully Insured</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span>Tracked Shipping</span></div>
            <div class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span>Ships in 3–5 Days</span></div>
          </div>

          {% assign title_lower = product.title | downcase %}
          <div class="accordions">

            {% if title_lower contains 'brook' and title_lower contains 'champagne' %}
