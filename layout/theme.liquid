<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: shop.description | default: 'MUNLER — Stainless steel frames and ecological mirrors. Crafted for the extraordinary home.' }}">
  <title>{% if template == 'index' %}MUNLER — Premium Home Objects{% elsif page_title %}{{ page_title }} | MUNLER{% else %}MUNLER{% endif %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <link rel="stylesheet" href="{{ 'style.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'pages.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'product.css' | asset_url }}">

  {% if template == 'policy' %}
  <style>
    .warranty-hero { position: relative; height: 90vh; min-height: 560px; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
    .warranty-hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
    .warranty-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,10,10,.55), rgba(10,10,10,.45)); }
    .warranty-hero-content { position: relative; z-index: 2; padding: 0 24px; max-width: 680px; }
    .warranty-hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.5rem, 7vw, 6.5rem); font-weight: 400; color: #fff; line-height: 1.05; }
    .warranty-body { padding: 8rem 0; background: #fff; }
    .policy-updated { font-family: 'Jost', sans-serif; font-size: .72rem; font-weight: 300; color: #888; letter-spacing: .08em; margin-bottom: 3.5rem; padding-bottom: 2rem; border-bottom: 1px solid #e8e4de; }
    .policy-section { margin-bottom: 3.5rem; padding-bottom: 3.5rem; border-bottom: 1px solid #e8e4de; }
    .policy-section h2 { font-family: 'Cormorant Garamond', serif !important; font-size: clamp(1.3rem, 2.5vw, 1.9rem) !important; font-weight: 400 !important; color: #1a1a18 !important; margin-bottom: 1.2rem !important; line-height: 1.2 !important; }
    .policy-section h3 { font-family: 'Jost', sans-serif !important; font-size: .78rem !important; font-weight: 500 !important; letter-spacing: .1em !important; text-transform: uppercase !important; color: #1a1a18 !important; margin-bottom: .8rem !important; margin-top: 1.8rem !important; font-style: normal !important; }
    .policy-section p { font-size: .88rem; line-height: 1.9; color: #6b6b67; margin-bottom: 1rem; }
    .policy-section ul, .policy-section ol { padding-left: 1.4rem; margin-bottom: 1rem; }
    .policy-section li { font-size: .88rem; line-height: 1.85; color: #6b6b67; margin-bottom: .4rem; }
    .policy-section a { color: #1a1a18 !important; text-decoration: underline; text-underline-offset: 3px; }
    .policy-section strong { color: #1a1a18; font-weight: 500; }
  </style>
  {% endif %}
</head>
<body>

  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <div class="announcement-track">
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Free UK Delivery</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Stainless steel frames</span>
      <span>&nbsp;&nbsp;·&nbsp;&nbsp;</span>
      <span>Ecological Mirrors</span>
    </div>
  </div>

  <!-- Header -->
  <header class="site-header" id="site-header">
    <div class="header-inner">
      <nav class="nav-left">
        <a href="/collections/all" class="nav-link">Shop</a>
        <a href="/collections" class="nav-link">Collections</a>
        <a href="/pages/trade" class="nav-link">Trade</a>
      </nav>

      <a href="/" class="site-logo">MUNLER</a>

      <div class="nav-right">
        <a href="/pages/about-munler" class="nav-link">About</a>
        <a href="/pages/contact" class="nav-link">Contact</a>
        <div class="nav-icons">
          <button class="icon-btn" aria-label="Search">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
          <a href="/cart" class="icon-btn cart-btn" aria-label="Cart">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-count" id="cart-count">{{ cart.item_count }}</span>
          </a>
        </div>
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/collections/all">Shop</a>
        <a href="/collections">Collections</a>
        <a href="/pages/trade">Trade</a>
        <a href="/pages/about-munler">About</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>
  </header>

  <main>
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">MUNLER</a>
        <p>Stainless steel frames<br>&amp; ecological mirrors.</p>
        <div class="footer-social">
          <a href="https://instagram.com/munleruk" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://pinterest.com/munleruk" aria-label="Pinterest">
