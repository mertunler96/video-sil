        </div>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h5>Shop</h5>
          <ul>
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections/mirrors">Mirrors</a></li>
