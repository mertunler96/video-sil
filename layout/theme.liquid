            <li><a href="/pages/about-munler">About Us</a></li>
            <li><a href="/pages/about-munler">Our Story</a></li>
            <li><a href="/pages/trade">Trade</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Support</h5>
          <ul>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/warranty">Warranty</a></li>
            <li><a href="/pages/shipping-returns">Shipping &amp; Returns</a></li>
            <li><a href="/pages/care-guide">Care Guide</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h5>Terms &amp; Policies</h5>
          <ul>
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
            <li><a href="/policies/refund-policy">Return &amp; Refund Policy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="payment-row">
      <div class="payment-icons">
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Visa"><rect width="46" height="30" rx="4" fill="#1A1F71"/><text x="23" y="20" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="900" font-style="italic" fill="#FFFFFF" letter-spacing="1">VISA</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Mastercard"><rect width="46" height="30" rx="4" fill="#1A1A1A"/><circle cx="18" cy="15" r="8.5" fill="#EB001B"/><circle cx="28" cy="15" r="8.5" fill="#F79E1B"/><path d="M23 7.2a8.5 8.5 0 0 1 0 15.6A8.5 8.5 0 0 1 23 7.2z" fill="#FF5F00"/></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="American Express"><rect width="46" height="30" rx="4" fill="#007BC1"/><text x="23" y="17" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="8" font-weight="700" fill="#FFFFFF" letter-spacing="0.4">AMERICAN</text><text x="23" y="25" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="8" font-weight="700" fill="#FFFFFF" letter-spacing="0.4">EXPRESS</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Apple Pay"><rect width="46" height="30" rx="4" fill="#000000"/><text x="23" y="20" text-anchor="middle" font-family="-apple-system,Arial,sans-serif" font-size="11" font-weight="500" fill="#FFFFFF">Pay</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Google Pay"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><text x="7" y="20" font-family="Arial,sans-serif" font-size="13" font-weight="700" fill="#4285F4">G</text><text x="19" y="20" font-family="Arial,sans-serif" font-size="11" font-weight="400" fill="#5F6368">Pay</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="PayPal"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><text x="5" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="900" fill="#003087">Pay</text><text x="26" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="900" fill="#009CDE">Pal</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Klarna"><rect width="46" height="30" rx="4" fill="#FFB3C7"/><text x="23" y="20" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="10" font-weight="700" fill="#000000" letter-spacing="0.3">klarna</text></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Maestro"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><circle cx="18" cy="15" r="8" fill="#0099DF" opacity="0.9"/><circle cx="28" cy="15" r="8" fill="#EB001B" opacity="0.85"/><path d="M23 7.7a8 8 0 0 1 0 14.6A8 8 0 0 1 23 7.7z" fill="#6C6BBD" opacity="0.9"/></svg>
        <svg class="pay-icon" viewBox="0 0 46 30" xmlns="http://www.w3.org/2000/svg" aria-label="Discover"><rect width="46" height="30" rx="4" fill="#FFFFFF" stroke="#D9D9D9" stroke-width="1"/><circle cx="34" cy="15" r="10" fill="#FF6600"/><text x="4" y="19" font-family="Arial,Helvetica,sans-serif" font-size="7" font-weight="700" fill="#231F20">DISC</text><text x="4" y="26" font-family="Arial,Helvetica,sans-serif" font-size="7" font-weight="700" fill="#231F20">OVER</text></svg>
